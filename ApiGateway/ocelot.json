{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/product/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "product-service",
          "Port": 8002
        }
      ],
      "UpstreamPathTemplate": "/api/product/{everything}",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PUT",
        "DELETE"
      ],
      "SwaggerKey": "product-service"
    },    
    {
      "DownstreamPathTemplate": "/api/order/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "order-service",
          "Port": 8003
        }
      ],
      "UpstreamPathTemplate": "/api/order/{everything}",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PUT",
        "DELETE"
      ],
      "SwaggerKey": "order-service"
    },
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "auth-service",
          "Port": 8000
        }
      ],
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PUT",
        "DELETE"
      ],
      "SwaggerKey": "auth-service"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "product-service",
      "Config": [
        {
          "Name": "Product Service API",
          "Version": "v1",
          "Url": "http://product-service:8002/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "order-service",
      "Config": [
        {
          "Name": "Order Service API",
          "Version": "v1",
          "Url": "http://order-service:8002/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "auth-service",
      "Config": [
        {
          "Name": "Auth Service API",
          "Version": "v1",
          "Url": "http://auth-service:8000/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:3000"
  }
}